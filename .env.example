# Database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postly

# Redis
# Format: redis://host:port
REDIS_URL=redis://localhost:6379

# JWT (REQUIRED - generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption Key (REQUIRED for AES-256-GCM)
# Generate a 32+ character key: openssl rand -hex 32
# ENCRYPTION_KEY=your-32-character-minimum-encryption-key

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token_from_botfather

# OpenAI API Key (optional - users can provide their own via bot)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic API Key (optional - users can provide their own via bot)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Twitter API credentials
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS (frontend URL for production)
# CORS_ORIGIN=http://localhost:3000

# Production Deployment (Render.com)
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com
